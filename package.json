{
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.15.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-glsl": "^0.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.21",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.3",
    "vitest-browser-svelte": "^2.1.0"
  },
  "dependencies": {
    "@threlte/core": "^8.5.9",
    "@threlte/extras": "^9.15.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/global.css"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "name": "@kuncat/avoidant",
  "peerDependencies": {
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kuncat/avoidant"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "npm run build:wasm && vite build",
    "build:wasm": "wasm-pack build crates/game --target web --out-dir ../../src/lib/wasm --out-name avoidant_wasm && rm -f src/lib/wasm/.gitignore",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "prepack": "npm run build:wasm && svelte-kit sync && svelte-package && rm -f dist/paraglide/.gitignore dist/paraglide/.prettierignore && publint",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "version": "0.1.0"
}
